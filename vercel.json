{
  "buildCommand": "prisma generate && next build",
  "installCommand": "npm install",
  "functions": {
    "src/app/api/auto-blog/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/cron/auto-blog/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/cron/researcher/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/cron/syndicator/route.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/auto-blog",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/researcher",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/syndicator",
      "schedule": "0 2 * * *"
    }
  ]
}
