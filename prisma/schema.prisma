generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==========================================
// AUTH & USERS
// ==========================================
model User {
  id                  String    @id @default(uuid())
  name                String    @default("")
  email               String    @unique
  password            String
  role                String    @default("AUTHOR") // SUPER_ADMIN, ADMIN, AUTHOR
  isVerified          Boolean   @default(true)
  twoFactorEnabled    Boolean   @default(false)
  twoFactorSecret     String?
  recoveryCodes       String?   // JSON array of recovery codes
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  otpCode             String?
  otpExpiry           DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  posts               BlogPost[]
}

// ==========================================
// BLOG SYSTEM
// ==========================================
model BlogPost {
  id              String    @id @default(uuid())
  title           String
  subtitle        String?
  slug            String    @unique
  content         String
  excerpt         String?
  featuredImage   String?
  status          String    @default("Draft")    // Published, Draft, Scheduled
  publishedAt     DateTime?
  scheduledAt     DateTime?
  expiryDate      DateTime?
  autoGenerated   Boolean   @default(false)
  allowAutoUpdate Boolean   @default(true)
  seoTitle        String?
  seoDescription  String?
  seoKeywords     String?   // comma-separated
  socialCaptions  String?
  socialHashtags  String?
  viewCount       Int       @default(0)
  translations    Json?     // Stores pre-translated content like { "hi": { "title": "...", "content": "..." } }
  authorId        String?
  author          User?     @relation(fields: [authorId], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tags            PostTag[]
  leads           Lead[]
  feedback        ReaderFeedback[]
  comments        Comment[]

  @@index([status, publishedAt])
  @@index([autoGenerated])
}

model ReaderFeedback {
  id        String   @id @default(uuid())
  postId    String
  post      BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  message   String
  type      String   @default("feedback") // feedback, typo, suggestion
  status    String   @default("new")      // new, reviewed, resolved
  createdAt DateTime @default(now())
}

model Tag {
  id        String    @id @default(uuid())
  name      String    @unique
  slug      String    @unique
  createdAt DateTime  @default(now())

  posts     PostTag[]
}

model PostTag {
  id      String   @id @default(uuid())
  postId  String
  tagId   String
  post    BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag     Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([postId, tagId])
}

// ==========================================
// SITE SETTINGS (singleton)
// ==========================================
model SiteSettings {
  id            String  @id @default("default")
  siteName      String?   @default("Our Blog")
  siteTagline   String?   @default("Your AI-powered blog")
  defaultLanguage String? @default("English")
  adminEmail    String?   @default("admin@example.com")
  aiProvider    String  @default("openai")    // openai, gemini, anthropic, deepseek
  aiApiKey      String  @default("")
  aiModel       String  @default("gpt-4o-mini")
  seoTitle      String  @default("Our Blog | AI-Powered Blog")
  seoDescription String @default("Advanced AI-Powered Blogging Platform")
  commentsEnabled Boolean @default(true)
  updatedAt     DateTime @updatedAt
}

// ==========================================
// LEAD GENERATION
// ==========================================
model Lead {
  id        String    @id @default(uuid())
  name      String
  email     String
  phone     String?
  company   String?
  website   String?
  message   String?
  source    String    @default("blog_form")  // blog_form, chatbot, popup, banner
  postId    String?
  post      BlogPost? @relation(fields: [postId], references: [id])
  status    String    @default("New")        // New, Contacted, Converted
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// ==========================================
// SOCIAL LINKS (Smart Banners)
// ==========================================
model SocialLink {
  id           String   @id @default(uuid())
  platform     String   // whatsapp, telegram, instagram, phone, email
  label        String   @default("")
  url          String
  imageUrl     String?
  isActive     Boolean  @default(true)
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ==========================================
// AD MANAGEMENT (AdSense)
// ==========================================
model AdPlacement {
  id          String   @id @default(uuid())
  name        String
  position    String   // header, sidebar, in_content, footer
  adCode      String   // The full ad script/code
  publisherId String?  // AdSense publisher ID
  isActive    Boolean  @default(true)
  priority    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==========================================
// AUTO-BLOGGING
// ==========================================
model AutoBlogKeyword {
  id        String    @id @default(uuid())
  keyword   String
  niche     String?
  status    String    @default("pending")  // pending, used, failed
  priority  Int       @default(0)
  usedAt    DateTime?
  postId    String?   // The post that was generated from this keyword
  createdAt DateTime  @default(now())

  @@index([status, priority, createdAt])
  @@index([createdAt])
}

model AutoBlogLog {
  id          String   @id @default(uuid())
  keyword     String
  title       String?
  status      String   // success, failed
  postId      String?
  error       String?
  createdAt   DateTime @default(now())
}

model AutoBlogSettings {
  id              String   @id @default("default")
  isActive        Boolean  @default(false)
  frequency       String   @default("daily")  // hourly, every6h, every12h, daily, weekly
  maxPostsPerRun  Int      @default(1)
  maxPostsPerDay  Int      @default(5)
  lastRunAt       DateTime?
  imageSource     String   @default("unsplash")  // unsplash, ai, none
  autoPublish     Boolean  @default(true)
  embedYoutube    Boolean  @default(true)
  isNewsActive    Boolean  @default(false)
  newsTopics      String?  @db.Text
  
  // Multi-Agent Settings
  researcherModel String   @default("google/gemini-2.5-flash")
  writerModel     String   @default("openai/gpt-4o-mini")
  seoModel        String   @default("openai/gpt-4o-mini")
    
    // Agent 11 Settings
    nicheSeedKeywords String? @db.Text
    targetCountry   String   @default("Global")
    
    // Agent 12 Settings
    mediumApiToken  String?
    bloggerApiToken String?
    tumblrApiToken  String?
    redditApiToken  String?
  
  // Social Media Auto-Post Settings
  instagramToken  String?
  instagramAccountId String?
  whatsappToken   String?
  whatsappPhoneId String?
  whatsappGroupId String? // The target group/number to post to
  twitter         String?
  telegramToken   String?
  telegramChatId  String?

  // Notification & Email Settings
  onesignalAppId  String?
  onesignalApiKey String?
  smtpHost        String?
  smtpPort        Int?
  smtpUser        String?
  smtpPass        String?

  updatedAt       DateTime @updatedAt
}

// ==========================================
// EXISTING MODELS (preserved)
// ==========================================
model ApiKey {
  id        String   @id @default(uuid())
  name      String
  provider  String
  apiKey    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Service {
  id          String   @id @default(uuid())
  title       String
  description String
  icon        String?
  imageUrl    String?
  status      String   @default("Active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Portfolio {
  id          String   @id @default(uuid())
  title       String
  category    String
  type        String
  imageUrl    String?
  websiteLink String?
  status      String   @default("Published")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model OutreachMessage {
  id          String   @id @default(uuid())
  leadId      String
  channel     String
  subject     String?
  body        String
  status      String   @default("draft")
  aiGenerated Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WebsiteAnalysis {
  id          String   @id @default(uuid())
  url         String
  report      String
  score       Int?
  createdAt   DateTime @default(now())
}

model AboutSetting {
  id          String   @id @default("default")
  heading     String   @default("About Us")
  content     String   @default("Welcome to our company.")
  mission     String?
  imageUrl    String?
  updatedAt   DateTime @updatedAt
}

model TeamMember {
  id          String   @id @default(uuid())
  name        String
  role        String
  bio         String   // Short excerpt
  fullDetails String   // Long HTML/text
  imageUrl    String?
  socialLinks String?  // JSON string
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}


model StaticPage {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  content   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Comment {
  id        String   @id @default(uuid())
  postId    String
  post      BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  author    String
  content   String
  approved  Boolean  @default(true)
  createdAt DateTime @default(now())
}
